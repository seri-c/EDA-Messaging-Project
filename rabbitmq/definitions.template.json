{
    "users": [
    {
      "name": "${RABBITMQ_USER}",
      "password_hash": "${RABBITMQ_PASSWORD_HASH}", 
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": "administrator"
    }
  ],
  "permissions": [
    
    {
      "user": "${RABBITMQ_USER}",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],

  "vhosts": [
    {
      "name": "/"
    }
  ],
  "exchanges": [
    {
      "name": "message.exchange",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false
    }
  ],
  "queues": [
    {
      "name": "email.queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false
    }
  ],
  "bindings": [
    {
      "source": "message.exchange",
      "vhost": "/",
      "destination": "email.queue",
      "destination_type": "queue",
      "routing_key": "message.created"
    }
  ]
}